# ── Ethara Environment Variables ────────────────────────────────────
# Copy this file to .env and customise values for your environment.
# Docker Compose reads .env automatically from the project root.

# PostgreSQL
POSTGRES_USER=ethara
POSTGRES_PASSWORD=ethara_secret
POSTGRES_DB=ethara_db

# Backend
DATABASE_URL=postgresql://ethara:ethara_secret@db:5432/ethara_db
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend (injected at build time)
REACT_APP_API_URL=http://localhost:8000
